<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.ScanMarker"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".CameraActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".MarkActivity"/>
        <activity android:name=".CropConfigActivity"/>
        <activity android:name=".batch.BatchCameraActivity"/>
        <activity android:name=".batch.BatchManagerActivity"/>
        <activity android:name=".batch.BatchProcessorActivity"/>

    </application>
</manifest>
